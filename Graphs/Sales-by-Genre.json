{
  "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
  "width": 550,
  "height": 400,
  "data": {
    "url": "https://raw.githubusercontent.com/mpaa0003/-2179----Data-Visualization---/refs/heads/main/Asgn2_Datasets/SalesByGenre.json"
  },
  "config": {
    "view": {"stroke": "transparent"},
    "axis": {"grid": true, "tickBand": "extent"}
  },
  "encoding": {
    "x": {
      "field": "Year",
      "type": "ordinal",
      "title": "Year",
      "axis": {"labelAngle": 30}
    },
    "y": {
      "field": "Genre",
      "type": "nominal",
      "title": "Music Genre",
      "sort": null,
      "axis": {
        "labelLimit": 250,
        "labelFontSize": 13,
        "titleFontSize": 16
      }
    }
  },
  "layer": [
    {
      "mark": "rect",
      "encoding": {
        "color": {
          "field": "percent",
          "type": "quantitative",
          "title": "Sales %",
          "scale": {"scheme": "purplebluegreen"},
          "legend": {"orient": "right", "gradientLength": 150}
        }
      }
    },
    {
      "mark": {"type": "text", "baseline": "middle"},
      "encoding": {
        "text": {"field": "percent", "type": "quantitative", "format": ".2f"},
        "color": {
          "condition": {"test": "datum['percent'] > 40", "value": "white"},
          "value": "black"
        }
      }
    }
  ]
}